# Copy to .env for local runs:  set -a; source .env; set +a
# (.env is gitignored — never commit real credentials.)

# Pass2U issuer (dashboard owner) login — the account that can see redemption records.
PASS2U_EMAIL=you@example.com
PASS2U_PASSWORD=your-password

# --- Google auth: OAuth (preferred; works when org policy blocks SA keys) ---
# CLIENT_ID/SECRET come from a "Desktop app" OAuth client in your GCP project.
# Get the refresh token once with: npm run auth
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxx

# --- Google auth: service account (fallback only) ---
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
