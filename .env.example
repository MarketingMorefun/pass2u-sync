# Copy to .env for local runs:  set -a; source .env; set +a
# (.env is gitignored — never commit real credentials.)

# --- Pass2U issuer login (the account that can see redemption records) ---
PASS2U_EMAIL=you@example.com
PASS2U_PASSWORD=your-password

# --- Google auth set 1: Sheets + Business Profile (Automations 1 & 2) ---
# Desktop OAuth client in the morefun-gbp-api project; authorized as the
# GBP-managing account. Scopes: spreadsheets + business.manage.
# Get the refresh token with: npm run auth
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxx

# --- Google auth set 2: Gmail (Automation 3, review-games abuse check) ---
# Same OAuth client values as above, but authorized as marketing@morefun.com.au.
# Scopes: gmail.readonly + gmail.send. Get the token with: npm run auth:gmail
GMAIL_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
GMAIL_OAUTH_REFRESH_TOKEN=1//xxxx
# Optional: where the abuse-check summary is sent (default marketing@morefun.com.au)
# REVIEW_ALERT_TO=someone@morefun.com.au

# --- Google auth fallback (service account) for Sheets only ---
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
